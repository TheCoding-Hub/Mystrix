local function createSpark(posX, posY)
    local spark = Instance.new("Frame")
    spark.Size = UDim2.new(0, math.random(3, 8), 0, math.random(3, 8))
    spark.Position = UDim2.new(0.5, posX + math.random(-20, 20), 0.65, posY + math.random(-20, 20))
    spark.BackgroundColor3 = Color3.fromRGB(255, math.random(100, 200), math.random(0, 50))
    spark.BorderSizePixel = 0
    spark.ZIndex = 10
    spark.Parent = LockContainer
    
    local targetX = posX + math.random(-150, 150)
    local targetY = posY + math.random(-120, 120)
    
    TweenService:Create(spark, TweenInfo.new(0.8, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Position = UDim2.new(0.5, targetX, 0.65, targetY),
        Size = UDim2.new(0, 1, 0, 1),
        BackgroundTransparency = 1
    }):Play()
    
    task.wait(0.8)
    spark:Destroy()
end

-- ========== EFEK FLASH BERULANG (MULTIPLE FLASHES) ==========
local function createRepeatingFlash(count, interval, maxSize)
    local flashes = {}
    
    for i = 1, count do
        task.spawn(function()
            task.wait((i - 1) * interval)
            
            local flash = Instance.new("Frame")
            flash.Size = UDim2.new(0, 100, 0, 100)
            flash.Position = UDim2.new(0.5, -50, 0.5, -50)
            flash.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            flash.BackgroundTransparency = 0.6
            flash.BorderSizePixel = 0
            flash.ZIndex = 15
            flash.Parent = LockContainer
            
            -- Efek getaran pada flash
            local originalPos = flash.Position
            local shakeConnection
            shakeConnection = RunService.RenderStepped:Connect(function()
                if not flash.Parent then 
                    shakeConnection:Disconnect()
                    return 
                end
                local offsetX = math.random(-8, 8)
                local offsetY = math.random(-8, 8)
                flash.Position = UDim2.new(originalPos.X.Scale, originalPos.X.Offset + offsetX, originalPos.Y.Scale, originalPos.Y.Offset + offsetY)
            end)
            
            -- Animasi flash membesar dan memudar
            TweenService:Create(flash, TweenInfo.new(0.15), {
                Size = UDim2.new(0, maxSize + (i * 20), 0, maxSize + (i * 20)),
                Position = UDim2.new(0.5, -(maxSize + (i * 20))/2, 0.5, -(maxSize + (i * 20))/2),
                BackgroundTransparency = 0.2
            }):Play()
            
            task.wait(0.12)
            
            TweenService:Create(flash, TweenInfo.new(0.1), {
                BackgroundTransparency = 1,
                Size = UDim2.new(0, maxSize + 50 + (i * 20), 0, maxSize + 50 + (i * 20)),
                Position = UDim2.new(0.5, -(maxSize + 50 + (i * 20))/2, 0.5, -(maxSize + 50 + (i * 20))/2)
            }):Play()
            
            task.wait(0.1)
            shakeConnection:Disconnect()
            flash:Destroy()
        end)
    end
end

