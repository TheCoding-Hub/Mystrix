-- Efek getaran untuk gembok (seperti sedang dipaksa)
local function shakeObject(obj, intensity, duration)
    local originalPos = obj.Position
    local startTime = tick()
    local connection
    connection = RunService.RenderStepped:Connect(function()
        if tick() - startTime > duration then
            obj.Position = originalPos
            connection:Disconnect()
            return
        end
        local offsetX = math.random(-intensity, intensity)
        local offsetY = math.random(-intensity, intensity)
        obj.Position = UDim2.new(originalPos.X.Scale, originalPos.X.Offset + offsetX, originalPos.Y.Scale, originalPos.Y.Offset + offsetY)
    end)
end

