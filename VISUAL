-- Efek patahnya busur gembok
local function breakLockArc()
    -- Potongan busur yang patah
    local brokenPiece1 = LockArc:Clone()
    brokenPiece1.Parent = LockContainer
    brokenPiece1.Size = UDim2.new(0, 60, 0, 40)
    brokenPiece1.Position = LockArc.Position
    brokenPiece1.Rotation = 0
    
    local brokenPiece2 = ArcTop:Clone()
    brokenPiece2.Parent = LockContainer
    brokenPiece2.Size = UDim2.new(0, 45, 0, 18)
    brokenPiece2.Position = ArcTop.Position
    brokenPiece2.Rotation = 0
    
    -- Sembunyikan yang asli
    LockArc.Visible = false
    ArcTop.Visible = false
    
    -- Lempar potongan ke arah berlawanan
    TweenService:Create(brokenPiece1, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Position = UDim2.new(0.5, math.random(-180, -80), 0.65, math.random(-150, -50)),
        Rotation = math.random(-120, -60),
        BackgroundTransparency = 1
    }):Play()
    
    TweenService:Create(brokenPiece2, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Position = UDim2.new(0.5, math.random(80, 180), 0.65, math.random(-150, -50)),
        Rotation = math.random(60, 120),
        BackgroundTransparency = 1
    }):Play()
    
    task.wait(0.6)
    brokenPiece1:Destroy()
    brokenPiece2:Destroy()
end

