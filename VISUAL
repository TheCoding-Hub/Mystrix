-- ========== PROGRESS SIMULATION (Cepat ke lambat) ==========
local progress = 0

-- Speed progression: dari cepat ke sangat lambat
-- speedFactor semakin kecil = semakin lambat
local steps = {
    {target = 8,    speed = 0.6},   -- Cepat
    {target = 18,   speed = 0.8},   -- Masih cepat
    {target = 29,   speed = 1.0},   -- Normal
    {target = 41,   speed = 1.3},   -- Mulai melambat
    {target = 55,   speed = 1.6},   -- Lebih lambat
    {target = 67,   speed = 1.9},   -- Lambat
    {target = 76,   speed = 2.2},   -- Semakin lambat
    {target = 84,   speed = 2.6},   -- Sangat lambat
    {target = 91,   speed = 3.0},   -- Lebih sangat lambat
    {target = 94.7, speed = 3.5},   -- Amat sangat lambat
    {target = 96.2, speed = 4.0},   -- Paling lambat sebelum stop
}

-- Circular progress animation
local function updateCircularProgress(pct)
    PercentText.Text = string.format("%.1f%%", pct)
    
    -- Update ring border intensity based on progress
    local intensity = 60 + (pct / 100) * 195
    CenterRing.BorderColor3 = Color3.fromRGB(255, intensity, intensity)
    RingGlow.BackgroundColor3 = Color3.fromRGB(255, intensity * 0.8, intensity * 0.8)
    
    -- Update status text based on progress
    if pct < 30 then
        StatusText.Text = "BYPASSING..."
    elseif pct < 60 then
        StatusText.Text = "PROCESSING..."
    elseif pct < 85 then
        StatusText.Text = "INJECTING..."
    else
        StatusText.Text = "FINALIZING"
    end
end

-- Start progress dengan efek cepat ke lambat
for _, step in ipairs(steps) do
    while progress < step.target do
        progress = math.min(progress + 0.3, step.target)
        updateCircularProgress(progress)
        -- Delay yang semakin besar = semakin lambat
        task.wait(step.speed * 0.1)
    end
    -- Jeda antar step juga semakin lama
    task.wait(step.speed * 0.3)
end

