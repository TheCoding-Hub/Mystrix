-- ========== PROGRESS SIMULATION (Sinkron semua bar) ==========
local mainProgress = 0
local statusMessages = {
    "Authenticating license",
    "Establishing secure channel",
    "Loading core modules",
    "Injecting protected routines",
    "Verifying integrity",
    "Synchronizing data",
    "Finalizing setup",
    "Almost ready"
}

local statusIndex = 1
local stepProgress = 0

-- Fungsi untuk mendapatkan kecepatan increment berdasarkan progress
local function getIncrement(currentProgress)
    if currentProgress > 90 then
        return 0.1
    elseif currentProgress > 80 then
        return 0.15
    elseif currentProgress > 70 then
        return 0.2
    elseif currentProgress > 60 then
        return 0.3
    elseif currentProgress > 50 then
        return 0.4
    elseif currentProgress > 40 then
        return 0.5
    elseif currentProgress > 30 then
        return 0.6
    elseif currentProgress > 20 then
        return 0.7
    elseif currentProgress > 10 then
        return 0.8
    else
        return 0.9
    end
end

-- Fungsi untuk mendapatkan delay berdasarkan progress
local function getDelay(currentProgress)
    if currentProgress > 90 then
        return 0.4
    elseif currentProgress > 80 then
        return 0.3
    elseif currentProgress > 70 then
        return 0.25
    elseif currentProgress > 60 then
        return 0.2
    else
        return 0.15
    end
end

-- Update detail bars (sinkron dengan main progress)
task.spawn(function()
    while ScreenGui.Parent and mainProgress < 100 do
        -- Update setiap detail bar mengikuti mainProgress
        for _, bar in ipairs(detailBars) do
            if bar.current < mainProgress then
                bar.current = math.min(bar.current + 0.5, mainProgress)
                local width = (bar.current / 100) * 0.5
                TweenService:Create(bar.fill, TweenInfo.new(0.1), {
                    Size = UDim2.new(width, 0, 1, 0)
                }):Play()
                bar.label.Text = math.floor(bar.current) .. "%"
                
                if bar.current >= 100 then
                    bar.fill.BackgroundColor3 = Color3.fromRGB(100, 200, 100)
                end
            end
        end
        task.wait(0.05)
    end
end)

-- Main progress simulation (semakin lambat di akhir)
task.spawn(function()
    while mainProgress < 97 do
        local increment = getIncrement(mainProgress)
        mainProgress = math.min(mainProgress + increment, 97)
        LoadPercent.Text = string.format("%.1f", mainProgress) .. "%"
        
        -- Update status text
        if mainProgress > stepProgress + 10 then
            stepProgress = mainProgress
            if statusIndex <= #statusMessages then
                StatusText.Text = statusMessages[statusIndex] .. ""
                statusIndex = statusIndex + 1
            end
        end
        
        -- Efek pulse
        local pulse = 0.3 + math.sin(mainProgress * 0.1) * 0.15
        CircleInner.BackgroundTransparency = pulse
        
        local loopDelay = getDelay(mainProgress)
        task.wait(loopDelay)
    end
    
    LoadPercent.Text = "97%"
    StatusText.Text = "Finalizing secure connection"
    print("[Mystrix Hub] Loading completed (97%) - waiting for manual completion")
end)

